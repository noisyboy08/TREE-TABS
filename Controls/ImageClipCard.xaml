<UserControl x:Class="Sowser.Controls.ImageClipCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="360" Height="260" MinWidth="120" MinHeight="80">
    <Border x:Name="RootBorder" Margin="8" CornerRadius="12" BorderBrush="#50FFFFFF" BorderThickness="1"
            Background="#28000000">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="#20FFFFFF" CornerRadius="12,12,0,0"
                    Cursor="SizeAll"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    MouseMove="TitleBar_MouseMove"
                    MouseLeftButtonUp="TitleBar_MouseLeftButtonUp">
                <Grid Margin="8,0">
                    <TextBlock Text="Screenshot" Foreground="#CCFFFFFF" VerticalAlignment="Center" FontSize="12"/>
                    <Button HorizontalAlignment="Right" Click="Close_Click"
                            Style="{StaticResource IconButtonStyle}" Width="28" Height="28" Foreground="#FF8888">
                        <TextBlock Text="✕" FontSize="14"/>
                    </Button>
                </Grid>
            </Border>
            <Image Grid.Row="1" x:Name="PreviewImage" Stretch="Uniform" Margin="6"/>
        </Grid>
    </Border>
</UserControl>
