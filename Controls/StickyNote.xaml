<UserControl x:Class="Sowser.Controls.StickyNote"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Width="300" Height="250" MinWidth="150" MinHeight="150">
    <Grid>
        <!-- Note Body - Glassmorphism -->
        <Border Margin="8" Background="#E0FFF9C4" CornerRadius="8" BorderBrush="#80FFFFFF" BorderThickness="1">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#CCFFE082" CornerRadius="8,8,0,0" Cursor="SizeAll" 
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                        MouseMove="TitleBar_MouseMove"
                        MouseLeftButtonUp="TitleBar_MouseLeftButtonUp">
                    <Button HorizontalAlignment="Right" Style="{StaticResource MaterialDesignIconButton}" 
                            Width="24" Height="24" Padding="0" Margin="0,0,4,0" Foreground="#BCAAA4" Click="CloseButton_Click">
                        <materialDesign:PackIcon Kind="Close" Width="14" Height="14"/>
                    </Button>
                </Border>
                <TextBox Grid.Row="1" x:Name="ContentBox" 
                         TextWrapping="Wrap" AcceptsReturn="True" 
                         Background="Transparent" BorderThickness="0"
                         Padding="12" FontSize="16" FontFamily="Segoe Print"
                         Foreground="#3E2723" TextChanged="ContentBox_TextChanged"
                         materialDesign:HintAssist.Hint="Write note here..."/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
